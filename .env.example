# Optional: improves paid-report wording. The calculation engine works without it.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-terra

# Required for production checkout. Never expose the secret key to browser code.
TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Keep false in production. Local development permits test checkout automatically.
PAYMENT_TEST_MODE=false
NEXT_PUBLIC_SITE_URL=https://example.com
SITE_INDEXABLE=false

# Required before public sales. Generate the encryption key with:
# node -e "console.log(require('node:crypto').randomBytes(32).toString('base64'))"
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
READING_ENCRYPTION_KEY=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Replace the draft legal text with these operator details before public launch.
SERVICE_OPERATOR_NAME=
SERVICE_BUSINESS_NUMBER=
SERVICE_ECOMMERCE_NUMBER=
SERVICE_OPERATOR_ADDRESS=
SERVICE_SUPPORT_EMAIL=
SERVICE_SUPPORT_PHONE=
